{
  "name": "takken-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "essences:dump": "node scripts/dump-questions.mjs",
    "essences:generate": "node scripts/generate-core-essences.mjs",
    "essences:merge": "node scripts/merge-core-essences.mjs",
    "explanations:audit": "npx tsx scripts/admin/audit_choice_statement.mjs",
    "explanations:generate": "npx tsx scripts/admin/enhance_explanations.mjs --apply",
    "explanations:apply": "npx tsx scripts/admin/apply_enhanced.mjs --apply",
    "explanations:all": "npm run explanations:audit && npm run explanations:generate && npm run explanations:apply"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/node": "^10.51.0",
    "@sentry/react-native": "^8.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^4.2.3",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "google-auth-library": "^9.14.1",
    "jsonwebtoken": "^9.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
