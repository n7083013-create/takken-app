{
  "expo": {
    "name": "宅建士 完全対策",
    "slug": "takken-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "takken-app",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.takken.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "宅建士 完全対策",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "NSUserNotificationsUsageDescription": "学習リマインダーや復習通知をお送りするために使用します",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.takken.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05b417d4-feb6-4ef1-aff0-888d2e0a377e"
      }
    },
    "owner": "naoyataira"
  }
}
